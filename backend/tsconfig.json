{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "sourceMap": true,

    "noImplicitAny": true,
    "strictNullChecks": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}